# =============================================================
# Production Environment Variables for Oracle Cloud Deployment
# Copy to .env.prod and fill in real values:
#   cp .env.prod.example .env.prod
# NEVER commit .env.prod to Git!
# =============================================================

# ── Django Core ───────────────────────────────────────────────
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-real-secret-key

# MUST be False in production
DEBUG=False

# Your domain name (and VM IP as fallback)
# Example: invoices.yourdomain.com,152.70.79.182
ALLOWED_HOSTS=YOUR_DOMAIN,152.70.79.182

# ── PostgreSQL ────────────────────────────────────────────────
# These are used by BOTH docker-compose (for the db container) and Django
POSTGRES_DB=invoices
POSTGRES_USER=invoices
POSTGRES_PASSWORD=change-me-to-a-strong-password

# These are used by Django when DATABASE_URL is not set
DB_ENGINE=django.db.backends.postgresql
DB_NAME=invoices
DB_USER=invoices
DB_PASSWORD=change-me-to-a-strong-password
DB_HOST=db
DB_PORT=5432

# ── CORS / CSRF ──────────────────────────────────────────────
# Comma-separated origins allowed to call the API
# Use https://YOUR_DOMAIN for production
CORS_ALLOWED_ORIGINS=https://YOUR_DOMAIN
CSRF_TRUSTED_ORIGINS=https://YOUR_DOMAIN

# ── SSL ───────────────────────────────────────────────────────
# Set to False initially (before obtaining SSL cert), then True
SECURE_SSL_REDIRECT=False

# ── Guest/Demo Account ───────────────────────────────────────
# Credentials for the one-click guest login button
GUEST_USERNAME=guest
GUEST_PASSWORD=change-me-guest-password

# ── Email (Optional) ─────────────────────────────────────────
# Uncomment and configure for password reset emails
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
