                  "const csrfToken = pm.environment.get('csrf_token');",
                  "console.log('CSRF Token from environment:', csrfToken);",
                  "console.log('CSRF Token length:', csrfToken ? csrfToken.length : 0);",
                  "",
                  "if (!csrfToken || csrfToken.length < 32) {",
                  "  console.error('ERROR: CSRF token is missing or invalid!');",
                  "  console.error('Please run \"Get CSRF Token\" request first.');",
                  "  throw new Error('CSRF token required. Run \"Get CSRF Token\" first.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
