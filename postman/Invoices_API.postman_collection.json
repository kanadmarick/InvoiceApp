    {
      "name": "Authentication",
      "item": [
        {
          "name": "Get CSRF Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const csrfCookie = pm.cookies.get('csrftoken');",
                  "console.log('CSRF Cookie:', csrfCookie);",
                  "console.log('CSRF Cookie Length:', csrfCookie ? csrfCookie.length : 0);",
                  "",
                  "pm.test('CSRF cookie exists', function () {",
                  "  pm.expect(csrfCookie).to.exist;",
                  "});",
                  "",
                  "pm.test('CSRF token has valid length', function () {",
                  "  pm.expect(csrfCookie).to.have.lengthOf.at.least(32);",
                  "});",
                  "",
                  "if (csrfCookie) {",
                  "  pm.environment.set('csrf_token', csrfCookie);",
                  "  console.log('CSRF token saved to environment:', pm.environment.get('csrf_token'));",
                  "}",
                  "",
                  "pm.test('CSRF token saved to environment', function () {",
                  "  const savedToken = pm.environment.get('csrf_token');",
                  "  pm.expect(savedToken).to.exist;",
                  "  pm.expect(savedToken).to.have.lengthOf.at.least(32);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/accounts/login/",
              "host": [
                "{{base_url}}"
              ],
